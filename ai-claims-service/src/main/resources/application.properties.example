# Application
spring.application.name=ai-claims-service
server.port=8083

# Database
spring.datasource.url=jdbc:mysql://localhost:3306/claims_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=your_password

# JWT
jwt.secret=your_jwt_secret_key

# Redis
spring.data.redis.host=localhost
spring.data.redis.port=6379

# Groq AI
groq.api.key=your_groq_api_key_here
groq.api.url=https://api.groq.com/openai/v1/chat/completions
groq.model=llama-3.3-70b-versatile

# Kafka
spring.kafka.bootstrap-servers=localhost:9092

# User Management Service
user.management.service.url=http://localhost:8081

# Internal API key
internal.api.key=your_internal_api_key